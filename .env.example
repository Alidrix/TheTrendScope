# Supabase configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT signing keys (keep secret)
JWT_CURRENT_KEY=your-jwt-current-key
JWT_STANDBY_KEY=your-jwt-standby-key
JWT_LEGACY_SECRET=your-legacy-jwt-secret

# YouTube Data API
YOUTUBE_API_KEY=your-youtube-api-key

# Allowed origins for CORS (comma-separated). Keep localhost for local dev.
APP_ORIGIN=http://localhost:4443

# Default admin credentials for local init:db
ADMIN_USER=your-admin-username
ADMIN_PASSWORD=your-strong-password

# Alert threshold (velocity per hour) used for notifications
ALERT_MIN_VELOCITY=5000
